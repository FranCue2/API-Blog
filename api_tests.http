### Variables
@hostname = localhost
@port = 8080
@host = {{hostname}}:{{port}}
@post_id = 697e5b5bbbc64501b97b0843
@delete_id = 697e5b5bbbc64501b97b0843

### Crear un nuevo post
POST http://{{host}}/posts
Content-Type: application/json

{
    "title": "Mi primer post en Go",
    "content": "Este es el contenido del blog usando MongoDB v2",
    "author": "Tu Nombre"
}

### Obtener todos los posts
GET http://{{host}}/posts
Accept: application/json

### Obtener un post por ID
GET http://{{host}}/posts/{{post_id}}
Accept: application/json

###Obetener posts con nombre
GET http://{{host}}/posts/search?title=Mi%20primer%20post%20en%20Go
Accept: application/json

###Obtener posts con author
GET http://{{host}}/posts/search?author=Tu%20Nombre
Accept: application/json

### Eliminar todos los posts
DELETE http://{{host}}/posts
Accept: application/json

### Eliminar un post por ID
DELETE http://{{host}}/posts/{{delete_id}}
Accept: application/json

### Nuevo Usuario
GET http://{{host}}/regiser?email=usuario%40correo.com&password=tu_contrase%C3%B1a
Content-Type: application/json

### Obtener Usuarios
GET http://{{host}}/users
Accept: application/json